{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mikcort",
  "version": "0.2.8",
  "identifier": "dev.mikcort.voice",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mikcort",
        "width": 980,
        "height": 680,
        "minWidth": 900,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http: https: ws: wss:; media-src 'self' blob:; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGMzAzMUE1RTJBOTkzNTYKUldSV2s2bmlwVEV3LzdMc1NkNWp1clpCTFY2V1RwR2VDUVNNMnZ3b2VkNDE5cUFiWFZxa0tkdHUK",
      "endpoints": [
        "https://github.com/mehmeCelenk/miccort/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
